# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Postgres connection for the read-only `nyit_web` role.
#
# Local development (via SSH tunnel — see DEPLOY.md):
#   ssh -L 5433:localhost:5432 root@194.233.88.142
#   then point at the tunnel:
# DATABASE_URL=postgres://nyit_web:CHANGE_ME@localhost:5433/nyit
#
# Production (on the VPS, DB is local):
# DATABASE_URL=postgres://nyit_web:CHANGE_ME@localhost:5432/nyit
DATABASE_URL=

# Base URL where the stocking app serves product images (the /uploads/... paths).
# Example (stocking app on port 3000):
# NEXT_PUBLIC_UPLOADS_BASE_URL=http://194.233.88.142:3000
NEXT_PUBLIC_UPLOADS_BASE_URL=
